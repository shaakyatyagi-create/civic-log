# ---------- Supabase (from Project Settings → API) ----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- CORS ----------
# Your deployed Vercel frontend URL. For local dev, http://localhost:5500 (or
# whatever static server you use) also works — comma-separate multiple origins.
CORS_ORIGIN=http://localhost:5500

# ---------- OpenAI ----------
# Leave blank to run in dry-run mode (simulated AI analysis + drafts).
OPENAI_API_KEY=

# ---------- Gmail API ----------
# Leave any of these blank to run in dry-run mode (emails logged, not sent).
# See scripts/get-gmail-token.js and SETUP.md for how to obtain these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER=shaakyatyagi@gmail.com

# ---------- X (Twitter) API ----------
# Leave any of these blank to run in dry-run mode (posts logged, not sent).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

PORT=8787
